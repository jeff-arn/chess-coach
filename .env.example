# Server-side API key for the LLM coach. Never prefix with NEXT_PUBLIC_.
# The coach falls back to rule-based explanations when this is absent.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model used by the coach.
# COACH_MODEL=claude-opus-4-8

# Path to the SQLite database file.
CHESS_COACH_DB=./chess-coach.db
